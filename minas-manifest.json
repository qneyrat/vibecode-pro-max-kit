{
  "version": "2.4.1",
  "include": [
    ".claude/agents/**",
    ".claude/skills/**",
    ".claude/skills/**/.??*",
    ".claude/hooks/**",
    ".claude/settings.json",
    ".minas/CLAUDE.md",
    ".minas/process/development-protocols/**",
    ".minas/process/context/planning/example-*.md",
    ".minas/process/_seeds/**",
    ".minas/process/_seeds/**/.gitkeep",
    ".minas/process/_seeds/**/.gitignore",
    ".minas/process/_seeds/**/.env.example"
  ],
  "exclude": [
    ".minas/process/context/all-context.md",
    ".minas/process/features/**",
    ".minas/process/general-plans/**",
    "**/.git/**",
    "**/.logs/**",
    ".claude/skills/minas-chrome-devtools/scripts/node_modules/**"
  ],
  "strip": [],
  "merge": [
    ".claude/settings.json"
  ],
  "copyIfMissing": [
    ".minas/process/context/planning/example-*.md"
  ],
  "symlinks": {
    ".agents/skills": "../.claude/skills"
  },
  "kitOnly": [
    "README.md",
    "README-preview*.html",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "TRADEMARK.md",
    "LICENSE",
    "docs/**",
    "assets/**",
    ".github/**",
    "resolve-manifest.mjs",
    "install.sh"
  ]
}
